{
  "annotations": {
    "list": []
  },
  "editable": true,
  "panels": [
    {
      "type": "timeseries",
      "title": "Container CPU Usage (%)",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total[5m])) * 100",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Container RAM Working Set (MiB)",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum by (name) (container_memory_working_set_bytes) / 1024 / 1024",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "mebibytes",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Frontend Total Requests",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 26 },
      "targets": [
        { "expr": "sum(frontend_requests_total) by (instance)", "legendFormat": "{{instance}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "title": "Frontend Request Errors",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 26 },
      "targets": [
        { "expr": "sum(frontend_requests_errors_total) by (instance)", "legendFormat": "{{instance}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "title": "Frontend Request Duration (s)",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 32 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(frontend_requests_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "A" },
        { "expr": "sum(rate(frontend_requests_duration_seconds_sum[5m])) / sum(rate(frontend_requests_duration_seconds_count[5m]))", "legendFormat": "Avg", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "title": "Backend Health Requests Total",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 38 },
      "targets": [
        { "expr": "sum(backend_health_requests_total) by (instance)", "legendFormat": "{{instance}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "title": "Backend Song Requests Total",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 38 },
      "targets": [
        { "expr": "sum(backend_song_requests_total) by (instance)", "legendFormat": "{{instance}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "title": "Backend Song Request Errors",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 44 },
      "targets": [
        { "expr": "sum(backend_song_request_errors_total) by (instance)", "legendFormat": "{{instance}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "title": "Backend Song Request Duration (s)",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 44 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(backend_song_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "A" },
        { "expr": "sum(rate(backend_song_request_duration_seconds_sum[5m])) / sum(rate(backend_song_request_duration_seconds_count[5m]))", "legendFormat": "Avg", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "barchart",
      "title": "Frontend Response Time Histogram (last 24h)",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "frontend_requests_duration_seconds_bucket",
          "legendFormat": "le={{le}}",
          "refId": "A",
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "showValue": "auto",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        },
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0
      }
    },
    {
      "type": "barchart",
      "title": "Backend Response Time Histogram (last 24h)",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "backend_song_request_duration_seconds_bucket",
          "legendFormat": "le={{le}}",
          "refId": "A",
          "instant": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "showValue": "auto",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        },
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "songbird"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timezone": "",
  "title": "Songbird",
  "version": 1
}
